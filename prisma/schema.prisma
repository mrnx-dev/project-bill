generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id         String    @id @default(uuid())
  name       String
  email      String?
  phone      String?
  isArchived Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
}

model Project {
  id                     String             @id @default(uuid())
  clientId               String
  title                  String
  status                 String             @default("to_do")
  totalPrice             Decimal            @db.Decimal(19, 4)
  dpAmount               Decimal?           @db.Decimal(19, 4)
  currency               String             @default("IDR")
  language               String             @default("id")
  deadline               DateTime?
  terms                  String?
  termsAcceptedAt        DateTime?
  termsAcceptedUserAgent String?
  termsAcceptedSessionId String?
  termsVersionId         Int?
  taxName                String?
  taxRate                Decimal?           @db.Decimal(19, 4)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  invoices               Invoice[]
  client                 Client             @relation(fields: [clientId], references: [id])
  items                  ProjectItem[]
  recurringInvoices      RecurringInvoice[]

  @@index([status])
  @@index([clientId])
}

model ProjectItem {
  id          String   @id @default(uuid())
  projectId   String
  description String
  price       Decimal  @db.Decimal(19, 4)
  quantity    Decimal? @db.Decimal(19, 4)
  rate        Decimal? @db.Decimal(19, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String    @id @default(uuid())
  invoiceNumber  String    @unique @default(uuid())
  projectId      String
  type           String
  notes          String?
  amount         Decimal   @db.Decimal(19, 4)
  status         String    @default("unpaid")
  emailStatus    String    @default("pending")
  dueDate        DateTime?
  paymentLink    String?
  paymentId      String?
  paidAt         DateTime?
  lastReminderAt DateTime?
  lateFeeApplied Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id])

  @@index([status])
  @@index([projectId])
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  password            String
  name                String
  role                String        @default("admin")
  onboardingCompleted Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  subscription        Subscription?
}

model Settings {
  id                 String   @id @default("global")
  companyName        String   @default("ProjectBill")
  companyAddress     String?
  companyEmail       String?
  senderEmail        String?
  companyLogoUrl     String?
  companyWhatsApp    String?
  resendApiKey       String?
  mayarApiKey        String?
  mayarWebhookSecret String?
  bankName           String?
  bankAccountName    String?
  bankAccountNumber  String?
  updatedAt          DateTime @updatedAt
}

model SOWTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  title      String?  // New field to capture context strings logically without polluting the action name
  entityType String?
  entityId   String?
  field      String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model RecurringInvoice {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  amount      Decimal   @db.Decimal(19, 4)
  frequency   String    @default("monthly")
  dayOfMonth  Int       @default(1)
  startDate   DateTime
  endDate     DateTime?
  nextRunAt   DateTime
  isActive    Boolean   @default(true)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([isActive, nextRunAt])
  @@index([projectId])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
}

model Subscription {
  id                 String    @id @default(uuid())
  userId             String    @unique
  plan               String    @default("starter")
  status             String    @default("active")
  mayarCustomerId    String?
  mayarPaymentId     String?
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  emailsSent         Int       @default(0)
  invoicesCreated    Int       @default(0)
  paymentLinksUsed   Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model AgentConversation {
  id        String   @id @default(uuid())
  title     String   @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  messages  AgentMessage[]

  @@index([userId, createdAt])
  @@index([userId])
}

model AgentMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant" | "system" | "tool"
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
}

model AgentMemory {
  id        String   @id @default(uuid())
  userId    String
  key       String   // "client_preferences", "project_patterns", "pricing_insights"
  value     Json
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

model AgentConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  provider       String   @default("openrouter")
  model          String   @default("anthropic/claude-sonnet-4-20250514")
  temperature    Float    @default(0.7)
  proactiveMode  Boolean  @default(true)
  locale         String   @default("id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
