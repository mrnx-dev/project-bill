generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id         String    @id @default(uuid())
  name       String
  email      String?
  phone      String?
  isArchived Boolean   @default(false)
  projects   Project[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Project {
  id                     String        @id @default(uuid())
  clientId               String
  client                 Client        @relation(fields: [clientId], references: [id])
  title                  String
  status                 String        @default("to_do") // to_do, in_progress, review, done
  totalPrice             Decimal       @db.Decimal(19, 4)
  dpAmount               Decimal?      @db.Decimal(19, 4)
  currency               String        @default("IDR") // IDR or USD
  language               String        @default("id") // "id" or "en"
  items                  ProjectItem[]
  invoices               Invoice[]
  deadline               DateTime?
  terms                  String?
  termsAcceptedAt        DateTime?
  termsAcceptedUserAgent String?
  termsAcceptedSessionId String?
  termsVersionId         Int?
  taxName                String?
  taxRate                Decimal?      @db.Decimal(19, 4)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  recurringInvoices      RecurringInvoice[]

  @@index([status])
  @@index([clientId])
}

model ProjectItem {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  price       Decimal  @db.Decimal(19, 4)
  quantity    Decimal? @db.Decimal(19, 4)
  rate        Decimal? @db.Decimal(19, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id             String    @id @default(uuid())
  invoiceNumber  String    @unique @default(uuid()) // E.g., INV-2026-0001
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  type           String // dp, full_payment, recurring
  notes          String?   @db.Text
  amount         Decimal   @db.Decimal(19, 4)
  status         String    @default("unpaid") // unpaid, paid
  emailStatus    String    @default("pending") // pending, sent, failed
  dueDate        DateTime?
  paymentLink    String?
  paymentId      String?
  paidAt         DateTime?
  lastReminderAt DateTime?
  lateFeeApplied Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([projectId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role                 String   @default("admin") // admin, staff
  onboardingCompleted  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Settings {
  id                 String   @id @default("global") // Enforce single row
  companyName        String   @default("ProjectBill")
  companyAddress     String?
  companyEmail       String?
  senderEmail        String?
  companyLogoUrl     String?
  companyWhatsApp    String?
  resendApiKey       String?
  mayarApiKey        String?
  mayarWebhookSecret String?
  
  // Bank Details for Manual Payment Fallback
  bankName          String? 
  bankAccountName   String?
  bankAccountNumber String?

  updatedAt          DateTime @updatedAt
}

model SOWTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // e.g., "settings.update", "invoice.create"
  entityType String?  // e.g., "Invoice", "Project", "Settings"
  entityId   String?  // e.g., invoice UUID
  field      String?  // e.g., "mayarApiKey"
  oldValue   String?  // masked value
  newValue   String?  // masked value
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model RecurringInvoice {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String    // Title or name of the retainer
  amount        Decimal   @db.Decimal(19, 4)
  frequency     String    @default("monthly") // monthly, weekly, yearly
  dayOfMonth    Int       @default(1)
  startDate     DateTime
  endDate       DateTime?
  nextRunAt     DateTime
  isActive      Boolean   @default(true)
  description   String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, nextRunAt])
  @@index([projectId])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   // payment, sow_signed, system
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
}
