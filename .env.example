# Database Configuration
DATABASE_URL="postgresql://projectbill_user:projectbill_password@localhost:5432/projectbill_db"
POSTGRES_USER="projectbill_user"
POSTGRES_PASSWORD="projectbill_password"
POSTGRES_DB="projectbill_db"

# Authentication
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET="your_generated_auth_secret_here"

# Encryption Key for API keys stored in database
# Generate using: openssl rand -hex 32
ENCRYPTION_KEY="your_64_char_hex_encryption_key_here"

# Cron Job Security
CRON_SECRET="your_random_cron_secret_here"

# Application URL
APP_URL="http://localhost:3000"
PORT=3000

# Deployment Mode
# "self-hosted" = All features unlimited, no subscription gates (default)
# "managed"     = Enables subscription tiers (Starter/Pro/Business)
DEPLOYMENT_MODE="self-hosted"

# Casdoor OIDC (Required for DEPLOYMENT_MODE="managed")
CASDOOR_ENDPOINT="https://auth.yourdomain.com"
CASDOOR_CLIENT_ID="your_client_id"
CASDOOR_CLIENT_SECRET="your_client_secret"
CASDOOR_ORG_NAME="your_org_name"

# Real-Time Updates (Optional for Self-Hosted, Required for Serverless)
# Enables Redis Pub/Sub for Server-Sent Events (SSE). If left empty, a local EventEmitter will be used.
REDIS_URL="redis://localhost:6379"

# Error Monitoring (Optional — compatible with Sentry or GlitchTip)
# Isi dengan DSN dari Sentry/GlitchTip. Kosongkan untuk menonaktifkan.
SENTRY_DSN=""

# AI Financial Co-Pilot (Optional)
# Enable AI assistant features for proactive insights, chat, and financial analysis
# Get your API key from https://openrouter.ai
AI_PROVIDER="openrouter"
AI_API_KEY="sk-or-v1-your_openrouter_key_here"
AI_MODEL="anthropic/claude-sonnet-4-20250514"
AI_BASE_URL="https://openrouter.ai/api/v1"
